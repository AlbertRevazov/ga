{
  "compilerOptions": {
    "target": "es6",
    "module": "nodenext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "nodenext", // Node environment
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "paths": {
      "@/*": ["./src/*"]
    },
    "experimentalDecorators": true,
    "incremental": true
  },
  "include": [
    "src",
    "declaration.d.ts" // Configure .d.ts file
  ],
  "exclude": ["node_modules"]
}
